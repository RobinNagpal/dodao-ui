# Copy to terraform.tfvars and fill in. DO NOT COMMIT terraform.tfvars.
# Secret VALUES (app_secrets) should be sourced from Secrets Manager by CI and passed as
# `-var` at apply time, NOT written to a committed file.

aws_region  = "us-east-1"
environment = "production"
domain_name = "koalagains.com"

ecr_repository_name = "insights-ui"
image_tag           = "REPLACE_WITH_GIT_SHA"

# Single-node Lightsail (scale MUST stay 1 — see variables.tf validation)
service_power = "medium" # 1 vCPU / 4 GB (Puppeteer headroom); "small" = 2 GB if it fits
service_scale = 1

# Database already lives in RDS — not provisioned here. Pass DATABASE_URL (pointing at the
# existing RDS endpoint) in app_secrets below.

existing_cloudfront_distribution_id = "EZI5H8FKNE9R1"
enable_static_asset_offload         = true

# Secret env — example only. In CI, build this map from Secrets Manager and pass via -var.
# app_secrets = {
#   DATABASE_URL          = "postgresql://user:pw@<existing-rds-endpoint>:5432/insights_ui_db?sslmode=require&connection_limit=5"
#   NEXTAUTH_SECRET       = "..."
#   DODAO_AUTH_SECRET     = "..."
#   EMAIL_TOKEN_SECRET    = "..."
#   OPENAI_API_KEY        = "..."
#   GOOGLE_API_KEY        = "..."
#   GOOGLE_CLIENT_ID      = "..."
#   GOOGLE_CLIENT_SECRET  = "..."
#   POLYGON_API_KEY       = "..."
#   AUTOMATION_SECRET     = "..."
#   KOALA_AWS_ACCESS_KEY_ID     = "..."
#   KOALA_AWS_SECRET_ACCESS_KEY = "..."
#   STOCK_ANALYZER_LAMBDA_URL   = "..."
#   ETF_ANALYZER_LAMBDA_URL     = "..."
#   # …remaining lambda URLs, OAuth (DISCORD_/TWITTER_), GEMINI_MODEL, LLM_PROVIDER, SCREENER_API_URL…
# }
