DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=some_access_key
AWS_SECRET_ACCESS_KEY=some_secret_key
KOALA_AWS_ACCESS_KEY_ID=some_access_key
KOALA_AWS_SECRET_ACCESS_KEY=some_secret_key
NEXT_PUBLIC_VERCEL_URL=localhost:3000
NEXT_PUBLIC_AGENT_APP_URL=http://localhost:5000
NEXT_PUBLIC_VERCEL_ENV=local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insights_ui_db?sslmode=verify-full&connection_limit=5
ADMIN_CODES=User1,User2

# NextAuth / Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret
DODAO_AUTH_SECRET=your-dodao-auth-secret
EMAIL_TOKEN_SECRET=your-email-token-secret
# for google login
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
# Set to your domain in production (e.g., .koalagains.com). If unset, browser defaults to current origin.
COOKIE_DOMAIN=
POLYGON_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
NEXT_PUBLIC_STOCK_ANALYZE_BASE_URL=
REMOTION_LAMBDA_URL=
FFMPEG_LAMBDA_NAME=
PPT_GENERATION_AWS_REGION=
PPT_GENERATION_AWS_ACCESS_KEY_ID=
PPT_GENERATION_AWS_SECRET_ACCESS_KEY=
PPT_GENERATION_S3_BUCKET_NAME=
## LLM provider/model are chosen per run in the report-generation UI. The FALLBACK
## default (when a run specifies none) is managed in the admin App Settings screen
## (LLM_DEFAULT_PROVIDER / LLM_DEFAULT_GEMINI_MODEL / LLM_DEFAULT_CLAUDE_MODEL, resolved
## SSM -> these env vars -> code default). See src/util/llm-default-config.ts.
LLM_DEFAULT_PROVIDER=
LLM_DEFAULT_GEMINI_MODEL=
LLM_DEFAULT_CLAUDE_MODEL=
## Tariff generation (optional): "true" runs each section synchronously (the old behavior); unset/false runs it in the background (returns fast, no 504) — the default.
GENERATE_TARIFF_SECTIONS_SYNCHRONOUSLY=
## Stock report generation: "true" runs the LLM call in-process in the background on this server (Lightsail); unset/false offloads to the AWS Lambda (old behavior).
USE_LAMBDA_FOR_LLM_RESPONSE=
## Claude subscription OAuth for the Claude provider (selected in the report-generation UI) on the background path (USE_LAMBDA_FOR_LLM_RESPONSE=false).
## PREFERRED: a long-lived refresh token (sk-ant-ort01-...). The app exchanges it for short-lived access tokens on demand and persists rotations to S3, so it is self-sustaining.
ANTHROPIC_OAUTH_REFRESH_TOKEN=
## FALLBACK: a static access token (sk-ant-oat01-...). Works but expires in hours and cannot self-refresh — local dev / bootstrap only.
ANTHROPIC_OAUTH_TOKEN=
## fetching information lambdas:
STOCK_ANALYZER_LAMBDA_URL=
SCREENER_API_URL=
ETF_ANALYZER_LAMBDA_URL=
ETF_MORN_LAMBDA_URL=
AUTOMATION_SECRET=

## App Settings (runtime config via AWS SSM Parameter Store — see docs/insights-ui/app-settings.md)
## When APP_CONFIG_SSM_ENABLED=true the admin "App Settings" screen reads/writes these values in SSM
## (reusing the AWS_* credentials above). When unset/false, values fall back to env vars / bundled defaults
## and the screen is read-only. Requires ssm:GetParametersByPath + ssm:PutParameter on the prefix below.
APP_CONFIG_SSM_ENABLED=
APP_CONFIG_SSM_PREFIX=/koalagains/insights-ui/