// --------------------------
// ETF Analysis Tables
// --------------------------

enum EtfAnalysisCategory {
  PerformanceAndReturns
  CostEfficiencyAndTeam
  RiskAnalysis
  FuturePerformanceOutlook
}

model EtfGenerationRequest {
  id    String @id @default(uuid())
  etfId String @map("etf_id")
  spaceId String @default("koala_gains") @map("space_id")

  regeneratePerformanceAndReturns Boolean @default(false) @map("regenerate_performance_and_returns")
  regenerateCostEfficiencyAndTeam Boolean @default(false) @map("regenerate_cost_efficiency_and_team")
  regenerateRiskAnalysis          Boolean @default(false) @map("regenerate_risk_analysis")
  regenerateFuturePerformanceOutlook Boolean @default(false) @map("regenerate_future_performance_outlook")
  regenerateIndexStrategy         Boolean @default(false) @map("regenerate_index_strategy")
  regenerateFinalSummary          Boolean @default(false) @map("regenerate_final_summary")

  status String @default("NotStarted") @map("status")

  inProgressStep String?  @map("in_progress_step")
  completedSteps String[] @default([]) @map("completed_steps")
  failedSteps    String[] @default([]) @map("failed_steps")

  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")
  lastInvocationTime DateTime? @map("last_invocation_time")

  etf Etf @relation(fields: [etfId], references: [id], onDelete: Cascade)

  @@index([etfId])
  @@index([status])
  @@index([etfId, status])
  @@map("etf_generation_requests")
}

model EtfCategoryAnalysisResult {
  id                     String              @id @default(uuid())
  categoryKey            EtfAnalysisCategory @map("category_key")
  summary                String              @map("summary")
  overallAnalysisDetails String              @map("overall_analysis_details")
  etfId                  String              @map("etf_id")
  spaceId                String              @default("koala_gains") @map("space_id")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  etf Etf @relation(fields: [etfId], references: [id], onDelete: Cascade)

  factorResults EtfAnalysisCategoryFactorResult[]

  @@unique([spaceId, etfId, categoryKey])
  @@index([etfId])
  @@map("etf_category_analysis_results")
}

model EtfAnalysisCategoryFactorResult {
  id                  String              @id @default(uuid())
  categoryKey         EtfAnalysisCategory @map("category_key")
  factorKey           String              @map("factor_key")
  oneLineExplanation  String              @map("one_line_explanation")
  detailedExplanation String              @map("detailed_explanation")
  result              EvaluationResult    @map("result")
  etfId               String              @map("etf_id")
  spaceId             String              @default("koala_gains") @map("space_id")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  etf Etf @relation(fields: [etfId], references: [id], onDelete: Cascade)

  categoryAnalysisResult EtfCategoryAnalysisResult @relation(fields: [spaceId, etfId, categoryKey], references: [spaceId, etfId, categoryKey], onDelete: Cascade)

  @@unique([spaceId, etfId, factorKey])
  @@index([etfId])
  @@index([spaceId, etfId, categoryKey], name: "etf_factor_results_by_parent")
  @@map("etf_analysis_category_factor_results")
}

model EtfCachedScore {
  id    String @id @default(uuid())
  etfId String @map("etf_id")

  performanceAndReturnsScore Int @map("performance_and_returns_score")
  costEfficiencyAndTeamScore Int @map("cost_efficiency_and_team_score")
  riskAnalysisScore          Int @map("risk_analysis_score")
  futurePerformanceOutlookScore Int? @map("future_performance_outlook_score")

  finalScore Int @map("final_score")

  etf Etf @relation(fields: [etfId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([etfId])
  @@index([etfId])
  @@map("etf_cached_scores")
}

// --------------------------
// ETF Similar ETFs
// --------------------------
// Per source-ETF list of similar/peer ETFs produced by the INDEX_STRATEGY LLM step.
// `matchedEtfId` is set when the (symbol, exchange, spaceId) pair exists in our `etfs` table.
model EtfSimilarEtf {
  id           String  @id @default(uuid())
  sourceEtfId  String  @map("source_etf_id")
  symbol       String  @map("symbol")
  exchange     String  @map("exchange")
  name         String? @map("name")
  reason       String? @map("reason") @db.Text
  sortOrder    Int     @default(0) @map("sort_order")
  matchedEtfId String? @map("matched_etf_id")
  spaceId      String  @default("koala_gains") @map("space_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sourceEtf  Etf  @relation("EtfSimilarEtfSource", fields: [sourceEtfId], references: [id], onDelete: Cascade)
  matchedEtf Etf? @relation("EtfSimilarEtfMatched", fields: [matchedEtfId], references: [id], onDelete: SetNull)

  @@unique([sourceEtfId, symbol, exchange])
  @@index([sourceEtfId])
  @@index([matchedEtfId])
  @@map("etf_similar_etfs")
}

// --------------------------
// ETF Market Scenarios
// --------------------------

// Direction / timeframe / probability / role are kept as plain TEXT columns;
// the strict string-literal unions live in `src/types/etfScenarioEnums.ts` so
// values can be added without a migration.

model EtfScenario {
  id                             String   @id @default(uuid())
  scenarioNumber                 Int      @map("scenario_number")
  title                          String   @map("title")
  slug                           String   @map("slug")
  underlyingCause                String   @map("underlying_cause") @db.Text
  historicalAnalog               String   @map("historical_analog") @db.Text
  winnersMarkdown                String   @map("winners_markdown") @db.Text
  losersMarkdown                 String   @map("losers_markdown") @db.Text
  outlookMarkdown                String   @map("outlook_markdown") @db.Text
  direction                      String   @default("DOWNSIDE") @map("direction")
  timeframe                      String   @default("FUTURE") @map("timeframe")
  probabilityBucket              String   @default("MEDIUM") @map("probability_bucket")
  probabilityPercentage          Int?     @map("probability_percentage")
  pricedInBucket                 String   @default("PARTIALLY_PRICED_IN") @map("priced_in_bucket")
  expectedPriceChange            Int?     @map("expected_price_change")
  expectedPriceChangeExplanation String?  @map("expected_price_change_explanation") @db.Text
  priceChangeTimeframeExplanation String? @map("price_change_timeframe_explanation") @db.Text
  outlookAsOfDate                DateTime @map("outlook_as_of_date") @db.Date
  metaDescription                String?  @map("meta_description") @db.Text
  archived                       Boolean  @default(false) @map("archived")
  spaceId                        String   @default("koala_gains") @map("space_id")
  createdAt                      DateTime @default(now()) @map("created_at")
  updatedAt                      DateTime @updatedAt @map("updated_at")

  etfLinks              EtfScenarioEtfLink[]

  @@unique([spaceId, scenarioNumber])
  @@unique([spaceId, slug])
  @@index([spaceId, archived])
  @@index([spaceId, direction])
  @@index([spaceId, timeframe])
  @@index([spaceId, probabilityBucket])
  @@index([spaceId, pricedInBucket])
  @@map("etf_scenarios")
}

model EtfScenarioEtfLink {
  id                             String   @id @default(uuid())
  scenarioId                     String   @map("scenario_id")
  etfId                          String?  @map("etf_id")
  symbol                         String   @map("symbol")
  exchange                       String?  @map("exchange")
  role                           String   @map("role")
  sortOrder                      Int      @default(0) @map("sort_order")
  roleExplanation                String?  @map("role_explanation") @db.Text
  expectedPriceChange            Int?     @map("expected_price_change")
  expectedPriceChangeExplanation String?  @map("expected_price_change_explanation") @db.Text
  spaceId                        String   @default("koala_gains") @map("space_id")
  createdAt                      DateTime @default(now()) @map("created_at")
  updatedAt                      DateTime @updatedAt @map("updated_at")

  scenario    EtfScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, symbol, role])
  @@index([scenarioId])
  @@index([symbol])
  @@map("etf_scenario_etf_links")
}
