  // Relation
  ticker TickerV1 @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@index([tickerId])
  @@index([status])
  @@index([tickerId, status]) // NEW: speeds up NOT EXISTS on ticker_id + status
  @@map("ticker_v1_generation_requests")
}

