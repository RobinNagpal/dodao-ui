{
  "groups": [
    {
      "key": "us-equity",
      "name": "US Equity",
      "description": "Diversified equity funds investing in US-listed companies — large/mid/small cap × blend/value/growth — plus broad-market funds (Total Market, Extended Market, High Dividend, US Equity). Analysis focuses on size/style tilt within the US market, peer comparison vs SPY / VTI / QQQ, and concentration risk for low-holdings funds."
    },
    {
      "key": "international-developed-equity",
      "name": "International Developed Equity",
      "description": "Equity funds investing outside the US in developed markets — Foreign Large/Small/Mid × Blend/Value/Growth, regional (Europe, Japan, Pacific), and Global variants that mix US with developed-international holdings. Analysis focuses on currency exposure, foreign-tax-credit eligibility, geographic diversification benefit, and peer comparison vs VXUS / VEA."
    },
    {
      "key": "emerging-markets-equity",
      "name": "Emerging Markets Equity",
      "description": "Equity funds with exposure to emerging-market economies — Diversified Emerging Markets and single-country emerging exposures (China, India, Latin America). Analysis focuses on currency volatility, political and regulatory risk, narrower underlying liquidity, single-country concentration, and peer comparison vs VWO / EEM / EMXC."
    },
    {
      "key": "sector-thematic-equity",
      "name": "Sector & Thematic Equity",
      "description": "Equity funds concentrated in a single sector, industry, or theme (technology, health, financials, real estate, energy, commodity-linked equities, infrastructure, etc.). Analysis focuses on sector cyclicality, concentration risk, top-holding exposure, and peer comparison within the sector or theme."
    },
    {
      "key": "leveraged-inverse",
      "name": "Leveraged & Inverse Trading",
      "description": "Daily-rebalanced leveraged, inverse, or multi-asset leveraged funds. Analysis focuses on daily-reset path dependency (decay), suitability strictly as short-term trading vehicles, accuracy of the daily-leverage objective, and holding-period warnings."
    },
    {
      "key": "fixed-income-investment-grade",
      "name": "Fixed Income — Investment Grade",
      "description": "Investment-grade bond funds where the dominant risk is interest rates: US Treasuries, agency MBS, investment-grade corporates, investment-grade securitized, TIPS, target maturity, and global IG bond funds. Analysis focuses on duration / rate sensitivity, yield, benchmark tracking, and resilience across interest-rate environments."
    },
    {
      "key": "fixed-income-floating-rate",
      "name": "Fixed Income — Floating Rate & Short Duration",
      "description": "Floating-rate and near-zero-duration income funds where the coupon resets with market rates: bank loans, AAA CLO tranches, ultrashort bond, and money market funds. Analysis focuses on credit-spread compensation, reset-rate behaviour, resilience to rate hikes, and credit-quality of the underlying loan or collateral pool. Duration risk is minimal."
    },
    {
      "key": "fixed-income-credit-and-income",
      "name": "Fixed Income — Credit & Income",
      "description": "Credit-driven and income-focused non-muni bond funds where default risk is the headline: high yield (centre of gravity for this group), preferred stock, convertibles, emerging-market debt, multisector, nontraditional, private debt, and sub-investment-grade CLO tranches. Analysis focuses on credit cycle, default rates, spread behaviour, and equity correlation during credit stress."
    },
    {
      "key": "muni",
      "name": "Municipal Bonds",
      "description": "All municipal bond funds — national, state-specific, high-yield muni, and muni target-maturity. Analysis focuses on tax-equivalent yield, federal-vs-state tax treatment, issuer credit quality, duration, and state or sector concentration."
    },
    {
      "key": "commodities-and-digital-assets",
      "name": "Commodities, Digital Assets & Currency",
      "description": "Funds providing direct exposure to physical commodities, digital assets, or single currencies. The fund holds (or tracks) the asset itself — there is no manager strategy in between. Analysis focuses on the asset's role in a portfolio (inflation hedge, diversifier, directional bet), tax wrappers (K-1 for some commodity funds, capital-gains treatment for crypto), and roll-yield / contango behaviour for futures-based products."
    },
    {
      "key": "strategy-funds",
      "name": "Strategy Funds (Hedge-Fund Style)",
      "description": "Hedge-fund-style funds where a manager runs an explicit process to generate returns that aim to be uncorrelated with the equity market: trend following, long-short equity, market neutral, macro, event-driven, relative-value arbitrage, multistrategy, and volatility / downside hedging. Analysis focuses on whether the strategy delivered on its mandate (lower volatility, downside protection, uncorrelated returns) vs an HFR sub-index — not absolute return vs a pure-equity benchmark."
    },
    {
      "key": "derivative-income",
      "name": "Derivative Income & Defined Outcome",
      "description": "Funds that mechanically engineer a payoff using options to generate income and/or define outcomes: covered call / put-write (Derivative Income), buffered (Defined Outcome), and collared / hedged equity (Equity Hedged). Analysis focuses on yield, upside cap, downside floor or buffer (where applicable), through-date (for buffered), and the distribution tax character (ordinary income vs return-of-capital)."
    },
    {
      "key": "allocation-target-date",
      "name": "Allocation & Target-Date",
      "description": "Funds with a prescribed asset-mix mandate — static allocation (moderate/aggressive/conservative), tactical allocation, global allocation variants, and all target-date glide-path funds. Analysis focuses on mandate adherence, tactical or glide-path execution, drawdown reduction vs pure-equity peers, and risk-adjusted returns within the allocation peer group."
    }
  ],
